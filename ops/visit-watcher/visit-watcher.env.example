PORTFOLIO_REPO_DIR=/home/kaan/my-portfolio
COMPOSE_ENV_FILE=/home/kaan/my-portfolio/.env.production
CADDY_SERVICE_NAME=caddy

# OpenClaw transport
OPENCLAW_BIN=/home/kaan/.openclaw/bin/openclaw
OPENCLAW_CHANNEL=telegram
OPENCLAW_TARGET=YOUR_TELEGRAM_USER_ID

# Optional: off | next-heartbeat | now
OPENCLAW_SYSTEM_EVENT_MODE=next-heartbeat

# Cooldown window for deduping one visitor session
ALERT_COOLDOWN_MS=900000

# Tail from only new log lines on start
CADDY_TAIL=0

# Acceptable status range for visit alerts
VISIT_STATUS_MIN=200
VISIT_STATUS_MAX=399
